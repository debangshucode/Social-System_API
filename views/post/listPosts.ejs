<!DOCTYPE html>
<html>

<head>
  <title>Posts</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>

<body class='w-full h-screen bg-gray-700 text-white justify-start flex-col gap-5 p-2'>


  <h1 class="text-2xl font-bold mb-4">All Posts</h1>

  <!-- Posts List -->
  <% if (data && data.length > 0) { %>
  <% data.forEach(post => { %>
  <div class="border border-2 p-2 bg-gray-500 mb-4">

    <p ><strong class="border border-2 border-red-900 px-2 rounded-md bg-red-700 mb-4">@<%= post.author.user_name %></strong></p>

    <p class="text-xl"><%= post.content %></p>

    <small class="text-green-500 font-bold">
      Created: <%= new Date(post.created_at).toLocaleString() %>
    </small>
    <br />

    <small class="text-blue-500">
      Likes: <%= post.likes_count %> |
      Comments: <%= post.comments_count %>
    </small>

  </div>
  <% }) %>
  <% } else { %>
  <p>No posts found.</p>
  <% } %>

  <!-- Pagination -->
  <div style="margin-top:20px;">

    <% if (links.previous) { %>
    <a class="hover:text-blue-500" href="<%= links.previous %>">Previous</a>
    <% } %>

    <span>
      Page <%= meta.currentPage %> of <%= meta.totalPages %>
    </span>

    <% if (links.next) { %>
    <a class="hover:text-blue-500" href="<%= links.next %>">Next</a>
    <% } %>

  </div>


</body>

</html>