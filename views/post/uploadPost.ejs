<!DOCTYPE html>
<html lang="en">
  <head>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@200..800&display=swap" rel="stylesheet">
    <style>
      body {
        font-family: "Manrope", sans-serif;
      }
    </style>
  </head>
  <body class="w-full h-screen bg-gray-700 flex justify-center items-center flex-col gap-5">
    <form class="border border-2 p-4 bg-white text-xl rounded-md flex flex-col gap-5 text-center w-2/3 h-1/2" action="/posts" method="post">
      <div class="flex flex-col gap-2 h-[90%]">
        <label class="self-baseline">Content:</label>
        <textarea class="focus:outline-none border border-2 border-gray rounded-md bg-white px-2 text-xl h-full p-2" type="text" name="content" required>
        </textarea>
      </div>
      <button class="hover:cursor-pointer hover:bg-green-500 hover:text-white w-fit mx-auto rounded-md p-2 transition duration-700 ease-in-out" type="submit">Upload</button>
    </form>
  </body>
</html>
