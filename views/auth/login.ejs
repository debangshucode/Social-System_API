<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Login</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="stylesheet" href="../../public/styles/tailwind/index.css">
</head>
<body class="w-full h-screen bg-gray-700 flex justify-center items-center flex-col gap-5">

  <h2 class="text-white text-xl font-bold"><%= title %></h2>

  <% if (error) { %>
    <p style="color: red;"><%= error %></p>
  <% } %>

  <form id="loginForm" class="border border-2 p-4 bg-white text-xl rounded-md flex flex-col gap-5 text-center" action="/auth/login" method="POST" >
    <div class="flex flex-col gap-2 ">
      <label class="self-baseline">Email:</label>
      <input class="focus:outline-none border border-2 border-gray rounded-md bg-white px-2 text-xl" type="email" name="email" required />
    </div>

    <div class="flex flex-col gap-2 ">
      <label  class="self-baseline">Password:</label>
      <input class="focus:outline-none border border-2 border-gray rounded-md bg-white px-2 text-xl" type="password" name="password" required />
    </div>

    <button class="hover:cursor-pointer hover:bg-green-500 hover:text-white w-fit mx-auto rounded-md p-2 transition duration-700 ease-in-out " type="submit">Login</button>

    <p class="text-sm">
      Already have an account?
      <span onclick="toggleForms()" class="text-blue-500 cursor-pointer">Login</span>
    </p>
  </form>

  

</body>
</html>
