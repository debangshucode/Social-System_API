<!DOCTYPE html>
<html>

<head>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@200..800&display=swap" rel="stylesheet">
    <style>
        body {
            font-family: "Manrope", sans-serif;
        }
    </style>
</head>

<body class="w-full h-screen  text-white ">

    <!-- *navbar  -->
    <div class="bg-white border-b border-gray p-2">
        <strong class="text-4xl text-[#4F46E5]">SocialSystem</strong>
    </div>

    <div class="max-w-7xl flex p-2 mx-auto">
        <div class="w-[70%]">
            <h1 class="text-5xl font-bold text-[#4F46E5]">
                <span class="text-[#000000]"> Welcome</span>
                <%= user.first_name + " " +user.last_name.split("")[0] %>
            </h1>
            <h2 class="text-xl font-semibold text-[#73768B]">
                @
                <%= profile.user_name %>
            </h2>
            <h2 class="text-xl font-semibold text-[#73768B]">
                <%= profile.bio %>
            </h2>
        </div>
        <button class="hover:cursor-pointer hover:bg-green-500 bg-green-600 font-semibold text-white text-xl border-2 w-fit h-fit mx-auto rounded-md p-2 transition duration-700 ease-in-out" onclick="window.location.href = '/posts/upload'">
      Add post
    </button>
        <button class="hover:cursor-pointer hover:bg-blue-500 bg-blue-600 font-semibold text-white text-xl border-2 w-fit h-fit mx-auto rounded-md p-2 transition duration-700 ease-in-out" onclick="window.location.href = '/posts'">
      see posts
    </button>

        <form action="/auth/logout" method="POST" class="h-fit">
            <button type="submit" class="h-full hover:cursor-pointer hover:bg-red-500 bg-red-600 font-semibold text-white text-xl border-2 w-fit h-fit mx-auto rounded-lg p-2 transition duration-700 ease-in-out">
        Logout
      </button>
        </form>
    </div>

    <div class="mt-8 max-w-7xl mx-auto">
        <%- include('../post/listPosts',{
      data:posts.data,
      meta:posts.meta,
      links:posts.links
    }) %>
    </div>

</body>


</html>