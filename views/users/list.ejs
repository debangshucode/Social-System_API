<!DOCTYPE html>
<html>
  <head>
    <script src="https://cdn.tailwindcss.com"></script>
  </head>
  <body class="w-full h-screen p-5">
    <div class="max-w-7xl">
      <h1 class="text-2xl font-bold text-blue-500 mb-4">Welcome <%= title %></h1>
      <button class="hover:cursor-pointer hover:bg-green-500 hover:text-white text-xl border-2 w-fit mx-auto rounded-md p-2 transition duration-700 ease-in-out" onclick="window.location.href = '/posts/upload'">Add post</button>
      <button class="hover:cursor-pointer hover:bg-blue-500 hover:text-white text-xl border-2 w-fit mx-auto rounded-md p-2 transition duration-700 ease-in-out" onclick="window.location.href = '/posts'">see posts</button>
    </div>
  </body>
</html>
