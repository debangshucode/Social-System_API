<div class="notification-page">
    <h1>Notifications</h1>
    <h2 class="notification-pf-name">@<%= profile %></h2>

    <div class="notifications">
       <!-- all notification -->
       <ul class="user-list">
        <% nData.forEach(function(notification) { %>
           <% if (notification.post) { %>
                <li class="user-card">

                    <form action="/notification/<%= notification.id %>/read" method="POST">
                    <%- include('../partials/csrf-field') %>
                    <input type="hidden" name="postId" value="<%= notification.post.id %>" />

                    <button type="submit" class="notif-submit">
                        
                        <p class="notif-row-full">
                        <%= notification.type[0].toUpperCase() + notification.type.slice(1).toLowerCase() %> Notification
                        </p>

                        <div class="users-data notif-users-data-full">
                        <div class="user-card-avatar">
                            <% if (notification.sender?.avatar_url) { %>
                            <img src="<%= notification.sender.avatar_url %>" class="avatar-sm" />
                            <% } else { %>
                            <div class="avatar-sm avatar-placeholder">
                                <%= (notification.sender?.user_name ?? 'U').charAt(0).toUpperCase() %>
                            </div>
                            <% } %>
                        </div>

                        <div class="notification-msg notif-message-row">
                            <span class="user-card-name"><%= notification.sender?.user_name %></span>
                            <% if (notification.message) { %>
                            <span class="user-card-bio"><%= notification?.message %></span> <span class="user-card-bio profile-bio-emphasis"><%= notification.post.content %></span>
                            <% } %>
                        </div>
                        </div>

                    </button>
                    </form>

                </li>
            <% } else { %>
                    <li class="user-card">
                        <form action="/notification/<%= notification.id %>/read" method="POST">
                            <%- include('../partials/csrf-field') %>
                            <input type="hidden" name="notificationType" value="<%= notification.type %>" />
                            <input type="hidden" name="profileId" value="<%= notification.sender?.id %>" />

                            <button type="submit" class="notif-submit">
                                <p class="notif-row-full">Follow request</p>
                                <div class="users-data">
                                    <div class="user-card-avatar">
                                        <% if (notification.sender?.avatar_url) { %>
                                            <img
                                                src="<%= notification.sender.avatar_url %>"
                                                alt="<%= notification.sender.user_name %>"
                                                class="avatar-sm"
                                            />
                                        <% } else { %>
                                            <div class="avatar-sm avatar-placeholder">
                                            <%= (notification.sender?.user_name ?? 'U').charAt(0).toUpperCase() %>
                                            </div>
                                        <% } %>
                                    </div>
                                    <div class="notification-msg">
                                        <span class="user-card-name"><%= notification.sender?.user_name %></span>
                                        <% if (notification.message) { %>
                                            <span class="user-card-bio"><%= notification.message %></span>
                                        <% } %>
                                    </div>

                                </div>
                            </button>
                        </form>
                    </li>
            <% } %>


        <% }) %>
      </ul>

      <% if (nMeta && nMeta.totalPages > 1) { %>
        <div class="pagination">
            <% if (nMeta.currentPage > 1) { %>
            <a href="/notification?page=<%= nMeta.currentPage - 1 %>" class="btn btn-sm btn-outline">&larr; Prev</a>
            <% } %>

            <span class="page-info">
            Page <%= nMeta.currentPage %> of <%= nMeta.totalPages %>
            </span>

            <% if (nMeta.currentPage < nMeta.totalPages) { %>
            <a href="/notification?page=<%= nMeta.currentPage + 1 %>" class="btn btn-sm btn-outline">Next &rarr;</a>
            <% } %>
        </div>
    <% } %>

    </div>
</div>
