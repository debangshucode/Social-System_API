<% if (!hasProfile) { %>

  <div class="profile-create-card">
    <h2>Set up your profile</h2>
    <p>Choose a username to get started.</p>
    <form method="POST" action="/profile/create">
      <div class="form-group" style="text-align:left">
        <label for="user_name">Username</label>
        <input id="user_name" type="text" name="user_name"
               required minlength="3" maxlength="30"
               placeholder="e.g. johndoe" />
      </div>
      <div class="form-group" style="text-align:left">
         <label for="bio">Bio <span style="color:#aaa;font-weight:400">(optional)</span></label>
        <textarea id="bio" name="bio" rows="3"
                  placeholder="Tell people a bit about yourself..."
                  maxlength="300"></textarea>
      </div>
      <button type="submit" class="btn btn-primary">Create profile</button>
    </form>
  </div>

<% } else { %>

<div class="profile-page">

  <!-- TOP SECTION -->
  <div class="profile-top">

    <div class="img-info">

      <!-- Avatar -->
      <div class="p-image">
        <% if (profile.avatar_url) { %>
          <img src="<%= profile.avatar_url %>" class="avatar-sm" />
        <% } else { %>
          <div class="avatar-xl avatar-placeholder">
            <%= profile.user_name.charAt(0).toUpperCase() %>
          </div>
        <% } %>
      </div>

      <!-- Info -->
      <div class="p-info">
        <h2><%= profile.user_name %></h2>
        <p><%= profile.bio %></p>
      </div>

      <!-- OWN PROFILE ACTION -->
      <div class="edit-profile">
        <a href="#" id="editBtn" class="btn btn-outline btn-sm" style="display: block;">
          Edit Profile
        </a>
        <form id="editForm" method="POST" action="/profile/edit" style="display:none;">
            <div class="form-group" style="text-align:left">
              <label for="user_name">Username</label>
              <input id="user_name" type="text" name="user_name"
                     minlength="3" maxlength="30" value="<%= profile.user_name %>"
                     placeholder="<%= profile.user_name %>" />
            </div>
            <div class="form-group" style="text-align:left">
               <label for="bio">Bio <span style="color:#aaa;font-weight:400">(optional)</span></label>
             <textarea id="bio" name="bio" rows="3" maxlength="300"><%= profile.bio %></textarea>
            </div>
            <button type="submit" class="btn btn-primary">Save profile</button>
          </form>
      </div>

    </div>

    <!-- STATS -->
    <div class="stats">

      
      <div class="flwrs">
        <button type="button" class="stat-btn" >
          <p class="count"><%= meta.totalItems %></p>
          <p class="count-text">Posts</p>
        </button>
      </div>

      <div class="flwrs">
        <button type="button" class="stat-btn" data-open-modal="followersModal">
          <p class="count"><%= fMeta.totalItems %></p>
          <p class="count-text">Followers</p>
        </button>
      </div>

      <div class="postC">
        <button type="button" class="stat-btn" data-open-modal="followingModal">
          <p class="count"><%= flMeta.totalItems %></p>
          <p class="count-text">Followings</p>
        </button>
      </div>

    </div>

  </div>

  <!-- AVATAR UPLOAD -->
  <div class="profile-section">
    <h2 style="font-size:1rem;margin-bottom:1rem">Profile picture</h2>

    <form method="POST" action="/profile/avatar" id="avatar-form">
      <input type="hidden" name="public_id" id="avatar-public-id" />
      <div style="display:flex;align-items:center;gap:1rem;flex-wrap:wrap">
          <label class="btn btn-outline btn-sm" style="cursor:pointer">
            Choose image
            <input type="file" id="avatar-file-input"
                   accept="image/jpeg,image/png,image/webp"
                   style="display:none"
                   onchange="handleAvatarFile(this)" />
          </label>
          <span id="avatar-file-name" style="font-size:.875rem;color:#666"></span>
          <button type="submit" id="avatar-submit-btn"
                  class="btn btn-primary btn-sm" disabled>
            Save avatar
          </button>
        </div>
        <p id="avatar-status" style="font-size:.825rem;margin-top:.5rem;color:#666"></p>
      </form>

       <% if (profile.avatar_url) { %>
        <form method="POST" action="/profile/avatar/remove" style="margin-top:.6rem">
          <button type="submit" class="btn btn-outline btn-sm"
                  style="color:#a32d2d;border-color:#f09595"
                  onclick="return confirm('Remove your avatar?')">
            Remove avatar
          </button>
        </form>
        <% } %>
  </div>

  <!-- POSTS -->
  <div class="profile-posts">
    <% data.forEach(function(post) { %>
      <article class="post-card">

            <!-- ! Post info -->
            <div class="post-card-meta">
              <% if (post.profile&& post.profile.avatar_url) { %>
                <img src="<%= post.profile.avatar_url %>"
                     alt="<%= post.profile.user_name %>"
                     class="avatar-sm" />
              <% } else { %>
                <div class="avatar-sm avatar-placeholder">
                  <%= (post.profile?.user_name ?? 'U').charAt(0).toUpperCase() %>
                </div>
              <% } %>
              <span class="post-author"><%= post.profile?.user_name ?? 'Unknown' %></span>
              <time class="post-time">
                <%= new Date(post.created_at).toLocaleDateString() %>
              </time>
            </div>

            <!-- ! Post content -->
            <p class="post-excerpt">
              <%= post.content ? post.content.slice(0, 200) : '' %>
              <% if (post.content && post.content.length > 200) { %>...
              <% } %>
            </p>

            <% if (post.media_path) { %>
              <div class="post-media" style="margin-bottom:1rem">
                <% if (post.media_type === 'VIDEO') { %>
                  <video controls style="width:100%;max-height:420px;border-radius:10px">
                    <source src="<%= post.media_path %>" type="<%= post.media_mime || 'video/mp4' %>" />
                  </video>
                <% } else { %>
                  <img
                    src="<%= post.media_path %>"
                    alt="Post media"
                    style="width:100%;max-height:420px;object-fit:cover;border-radius:10px" />
                <% } %>
              </div>
            <% } %>

            <!-- ! Post like and comments -->
            <div class="post-card-footer">
              <span class="post-stat"><%= post.likes_count ?? 0 %> likes</span>
              <span class="post-stat"><%= post.comments_count ?? 0 %> comments</span>
              <a href="/posts/<%= post.id %>" class="btn btn-sm btn-outline">
                Read more
              </a>
            </div>
          </article>
    <% }) %>
  </div>

  <!-- PAGINATION -->
  <% if (meta && meta.totalPages > 1) { %>
    <div class="pagination">

      <% if (meta.currentPage > 1) { %>
        <a href="/profile?page=<%= meta.currentPage - 1 %>" class="btn btn-sm btn-outline">
          Prev
        </a>
      <% } %>

      <span class="page-info">
        Page <%= meta.currentPage %> of <%= meta.totalPages %>
      </span>

      <% if (meta.currentPage < meta.totalPages) { %>
        <a href="/profile?page=<%= meta.currentPage + 1 %>" class="btn btn-sm btn-outline">
          Next
        </a>
      <% } %>

    </div>
  <% } %>

</div>

<% } %>
<%- include('../partials/follow-list-modal', {
  modalId: 'followersModal',
  title: 'Followers',
  items: fData,
  meta:fMeta,
  userKey: 'follower',
  basePath: '/profile',
  pageParam: 'followersPage',
  otherPageParam: 'followingPage',
  otherCurrentPage: flMeta?.currentPage || 1
}) %>

<%- include('../partials/follow-list-modal', {
  modalId: 'followingModal',
  title: 'Following',
  items: flData,
  meta:flMeta,
  userKey: 'following',
  basePath: '/profile',
  pageParam: 'followersPage',
  otherPageParam: 'followingPage',
  otherCurrentPage: flMeta?.currentPage || 1
}) %>

<script>
  const editBtn = document.getElementById("editBtn");
  const form = document.getElementById("editForm");

  editBtn.addEventListener("click", function (e) {
    e.preventDefault();
    form.style.display = "block";
    editBtn.style.display = "none";
  });
</script>

<script>
  document.addEventListener('click', (e) => {
    const openBtn = e.target.closest('[data-open-modal]');
    if (openBtn) {
      const id = openBtn.getAttribute('data-open-modal');
      const modal = document.getElementById(id);
      if (modal) modal.hidden = false;
    }

    if (e.target.matches('[data-close-modal]')) {
      const modal = e.target.closest('.modal-backdrop');
      if (modal) modal.hidden = true;
    }

    if (e.target.classList.contains('modal-backdrop')) {
      e.target.hidden = true;
    }
  });

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') {
      document.querySelectorAll('.modal-backdrop').forEach(m => m.hidden = true);
    }
  });
</script>



<script>
  async function handleAvatarFile(input) {
    const file = input.files[0];
    if (!file) return;

    document.getElementById('avatar-file-name').textContent = file.name;
    document.getElementById('avatar-status').textContent = 'Uploading...';
    document.getElementById('avatar-submit-btn').disabled = true;

    try {
      const sigRes = await fetch('/api/avatar/sign', {
        credentials: 'include',
      });

      if (!sigRes.ok) throw new Error('Could not get upload signature');
      const sig = await sigRes.json();

      const fd = new FormData();
      fd.append('file',       file);
      fd.append('api_key',    sig.api_key);
      fd.append('timestamp',  sig.timeStamp);
      fd.append('signature',  sig.signature);
      fd.append('public_id',  sig.public_id);

      const upRes = await fetch(
        `https://api.cloudinary.com/v1_1/${sig.cloud_name}/image/upload`,
        { method: 'POST', body: fd }
      );
      if (!upRes.ok) throw new Error('Cloudinary upload failed');
      const up = await upRes.json();

      document.getElementById('avatar-public-id').value = up.public_id;
      document.getElementById('avatar-submit-btn').disabled = false;
      document.getElementById('avatar-status').textContent = 'Ready — click Save avatar';
    } catch (e) {
      document.getElementById('avatar-status').textContent = e.message;
    }
  }
  </script>

<script>
  const params = new URLSearchParams(window.location.search);
  const openModalId = params.get('openModal');
  if (openModalId) {
    const modal = document.getElementById(openModalId);
    if (modal) modal.hidden = false;
  }
</script>
