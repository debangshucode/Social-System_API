<article class="post-detail">
  <div class="post-detail-meta">
    <% if (post.profile && post.profile.avatar_url) { %>
      <img src="<%= post.profile.avatar_url %>"
           alt="<%= post.profile.user_name %>"
           class="avatar-sm" />
    <% } else { %>
      <div class="avatar-sm avatar-placeholder">
        <%= (post.profile?.user_name ?? 'U').charAt(0).toUpperCase() %>
      </div>
    <% } %>
    <div>
      <strong><%= post.profile?.user_name ?? 'Unknown' %></strong>
      <time><%= new Date(post.created_at).toLocaleDateString() %></time>
    </div>
  </div>

  <div class="post-body"><%= post.content %></div>

  <% if (post.media_path) { %>
      <div class="post-media post-media-spaced">
        <% if (post.media_type === 'VIDEO') { %>
          <video controls class="media-video">
            <source src="<%= post.media_path %>" type="<%= post.media_mime || 'video/mp4' %>" />
          </video>
        <% } else { %>
          <img
            src="<%= post.media_path %>"
            alt="Post media"
            class="media-image-contain" />
        <% } %>
      </div>
    <% } %>

  <!-- Like / Unlike — works without JS, two separate forms -->
  <div class="post-actions">
    <% if ( post.profile && post.liked_by_me) { %>
      <form method="POST" action="/posts/<%= post.id %>/unlike">
        <%- include('../partials/csrf-field') %>
        <button type="submit" class="btn btn-sm btn-liked">
          <i class="fa-solid fa-heart icon-gap-right"></i> Unlike &nbsp;<span class="count"><%= post.likes_count ?? 0 %></span>
        </button>
      </form>
    <% } else if(post.profile) { %>
      <form method="POST" action="/posts/<%= post.id %>/like">
        <%- include('../partials/csrf-field') %>
        <button type="submit" class="btn btn-sm btn-outline" >
         <i class="fa-regular fa-heart icon-gap-right"></i> Like &nbsp;<span class="count"><%= post.likes_count ?? 0 %></span>
        </button>
      </form>
    <% }else { %>
      <form >
        <button type="submit" class="btn btn-sm btn-outline" disabled>
         <i class="fa-regular fa-heart icon-gap-right"></i> Like &nbsp;<span class="count"><%= post.likes_count ?? 0 %></span>
        </button>
      </form>
      <% } %>
  </div>
</article>

<!-- Comments preview (from post.comments_preview if any) -->
<% if (post.comments_preview && post.comments_preview.length > 0) { %>
  <section class="comments-preview">
    <h3>Recent comments</h3>
    <% post.comments_preview.forEach(function(c) { %>
      <div class="comment">
        <span class="comment-author"><%= c.profile?.user_name ?? 'User' %></span>
        <p><%= c.content %></p>
      </div>
    <% }) %>
  </section>
<% } %>

<!-- Full comment thread -->
<section class="comments-section">
  <h2>Comments
    <% if (commentsMeta) { %>
      (<%= commentsMeta.totalItems ?? comments.length %>)
    <% } %>
  </h2>

  <!-- Add comment form -->
   <% if(post.profile) { %>
  <form method="POST"
        action="/posts/<%= post.id %>/comment"
        class="comment-form">
    <%- include('../partials/csrf-field') %>
    <textarea name="content"
              rows="3"
              placeholder="Write a comment..."
              required
              maxlength="1000"></textarea>
    <button type="submit" class="btn btn-primary btn-sm">
      Post comment
    <i class="fa-solid fa-paper-plane icon-white icon-gap-left"></i>
    </button>
    
  </form>
  <% } %>

  <!-- Comment list -->
  <% if (!comments || comments.length === 0) { %>
    <p class="empty">No comments yet.</p>
  <% } else { %>
    <% comments.forEach(function(c) { %>
      <div class="comment">
        <div class="comment-header">
          <span class="comment-author">
            <%= c.profile?.user_name ?? 'User' %>
          </span>
          <time><%= new Date(c.created_at).toLocaleDateString() %></time>
        </div>
        <p><%= c.content %></p>
      </div>
    <% }) %>
  <% } %>

  <!-- Comment pagination -->
  <% if (commentsMeta && commentsMeta.totalPages > 1) { %>
    <div class="pagination">
      <% if (commentsMeta.currentPage > 1) { %>
        <a href="/posts/<%= post.id %>?page=<%= commentsMeta.currentPage - 1 %>"
           class="btn btn-sm btn-outline">&larr; Prev</a>
      <% } %>
      <span class="page-info">
        Page <%= commentsMeta.currentPage %> of <%= commentsMeta.totalPages %>
      </span>
      <% if (commentsMeta.currentPage < commentsMeta.totalPages) { %>
        <a href="/posts/<%= post.id %>?page=<%= commentsMeta.currentPage + 1 %>"
           class="btn btn-sm btn-outline">Next &rarr;</a>
      <% } %>
    </div>
  <% } %>
</section>
