<div class="feed-header">
  <h1>Feed</h1>
</div>
<!-- add post  -->

<div class="feed-header">
  <button class="btn btn-primary btn-sm"
          onclick="document.getElementById('add-post-form').style.display = document.getElementById('add-post-form').style.display === 'none' ? 'block' : 'none'">
    + New post
  </button>
</div>

<div id="add-post-form" style="display:none;background:#fff;border:1px solid #e5e4df;border-radius:10px;padding:1.25rem;margin-bottom:1.25rem">
  <form method="POST" action="/feed/post" enctype="multipart/form-data" id="create-post-form">
    <div class="form-group">
      <label for="post-content">What's on your mind?</label>
      <textarea id="post-content" name="content" rows="4" required placeholder="Write your post..."></textarea>

      <label for="post-media">Attach media (optional)</label>
      <input
        id="post-media"
        type="file"
        name="media"
        accept="image/jpeg,image/png,image/webp,video/mp4,video/webm" 
      />
      <p id="post-media-error" style="color:#a32d2d;font-size:.82rem;margin-top:.4rem;display:none"></p>
    </div>

    <div style="display:flex;gap:.6rem;justify-content:flex-end">
      <button type="button" class="btn btn-outline btn-sm"
              onclick="document.getElementById('add-post-form').style.display='none'">
        Cancel
      </button>
      <button type="submit" class="btn btn-primary btn-sm">Publish</button>
    </div>
  </form>
</div>

<!-- feed -->
<% if (!posts || posts.length === 0) { %>
  <p class="empty">No posts yet. Be the first!</p>
<% } else { %>
  <div class="post-list">
    <% posts.forEach(function(post) { %>
      <article class="post-card">
        <div class="post-card-meta">
          <% if (post.profile&& post.profile.avatar_url) { %>
            <img src="<%= post.profile.avatar_url %>"
                 alt="<%= post.profile.user_name %>"
                 class="avatar-sm" />
          <% } else { %>
            <div class="avatar-sm avatar-placeholder">
              <%= (post.profile?.user_name ?? 'U').charAt(0).toUpperCase() %>
            </div>
          <% } %>
          <span class="post-author"><%= post.profile?.user_name ?? 'Unknown' %></span>
          <time class="post-time">
            <%= new Date(post.created_at).toLocaleDateString() %>
          </time>
        </div>

        <p class="post-excerpt">
          <%= post.content ? post.content.slice(0, 200) : '' %>
          <% if (post.content && post.content.length > 200) { %>...
          <% } %>
        </p>

        <% if (post.media_path) { %>
            <div class="post-media" style="margin-bottom:1rem">
              <% if (post.media_type === 'VIDEO') { %>
                <video controls style="max-height:420px;border-radius:10px">
                  <source src="<%= post.media_path %>" type="<%= post.media_mime || 'video/mp4' %>" />
                </video>
              <% } else { %>
                <img
                  src="<%= post.media_path %>"
                  alt="Post media"
                  style="max-height:420px;object-fit:contain;border-radius:10px" />
              <% } %>
            </div>
          <% } %>


        <div class="post-card-footer">
          <span class="post-stat"><%= post.likes_count ?? 0 %> likes</span>
          <span class="post-stat"><%= post.comments_count ?? 0 %> comments</span>
          <a href="/posts/<%= post.id %>" class="btn btn-sm btn-outline">
            Read more
          </a>
          <form action="/posts/<%= post.id %>/delete" method="POST">
            <button type="submit" style="background:none; border:none; cursor:pointer;">
              <i class="fa-solid fa-trash-can"></i>
            </button>
          </form>
        </div>
      </article>
    <% }) %>
  </div>

  <!-- Pagination -->
  <% if (meta && meta.totalPages > 1) { %>
    <div class="pagination">
      <% if (meta.currentPage > 1) { %>
        <a href="/feed?page=<%= meta.currentPage - 1 %>"
           class="btn btn-sm btn-outline">&larr; Prev</a>
      <% } %>
      <span class="page-info">
        Page <%= meta.currentPage %> of <%= meta.totalPages %>
      </span>
      <% if (meta.currentPage < meta.totalPages) { %>
        <a href="/feed?page=<%= meta.currentPage + 1 %>"
           class="btn btn-sm btn-outline">Next &rarr;</a>
      <% } %>
    </div>
  <% } %>
<% } %>

<script>
  (function () {
    const form = document.getElementById('create-post-form');
    const mediaInput = document.getElementById('post-media');
    const errorEl = document.getElementById('post-media-error');
    if (!form || !mediaInput || !errorEl) return;

    const MAX_FILE_SIZE = 10 * 1024 * 1024; // 10MB

    const showError = (message) => {
      errorEl.textContent = message;
      errorEl.style.display = 'block';
    };

    const clearError = () => {
      errorEl.textContent = '';
      errorEl.style.display = 'none';
    };

    mediaInput.addEventListener('change', () => {
      const file = mediaInput.files?.[0];
      if (!file) {
        clearError();
        return;
      }

      if (file.size > MAX_FILE_SIZE) {
        mediaInput.value = '';
        showError('File too large. Max allowed size is 10MB.');
        return;
      }
      clearError();
    });

    form.addEventListener('submit', (e) => {
      const file = mediaInput.files?.[0];
      if (file && file.size > MAX_FILE_SIZE) {
        e.preventDefault();
        showError('File too large. Max allowed size is 10MB.');
      }
    });
  })();
</script>
