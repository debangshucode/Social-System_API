<div class="chat-room" style="max-width:960px;margin:0 auto;">
  <div
    class="chat-room-card"
    style="background:#fff;border:1px solid #e5e4df;border-radius:18px;overflow:hidden;box-shadow:0 16px 40px rgba(26,26,24,0.08);"
  >
    <div
      class="chat-room-header"
      style="display:flex;align-items:center;justify-content:space-between;gap:1rem;padding:1.25rem 1.5rem;border-bottom:1px solid #eceae3;background:linear-gradient(135deg,#f8f7f2 0%,#f1efe6 100%);"
    >
      <div style="display:flex;align-items:center;gap:1rem;min-width:0;">
        <% if (chatprofile?.avatar_url) { %>
          <img
            src="<%= chatprofile.avatar_url %>"
            alt="<%= chatprofile.user_name %>"
            style="width:56px;height:56px;border-radius:50%;object-fit:cover;border:2px solid #fff;"
          />
        <% } else { %>
          <div
            style="width:56px;height:56px;border-radius:50%;display:grid;place-items:center;background:#534ab7;color:#fff;font-weight:700;font-size:1.1rem;"
          >
            <%= (chatprofile?.user_name ?? 'U').charAt(0).toUpperCase() %>
          </div>
        <% } %>

        <div style="min-width:0;">
          <h1 style="font-size:1.2rem;line-height:1.2;"><%= chatprofile?.user_name ?? 'Chat user' %></h1>
          <p style="margin-top:.2rem;color:#666;font-size:.9rem;">
            <%= chatprofile?.bio || 'Start the conversation.' %>
          </p>
        </div>
      </div>

      <div style="text-align:right;flex-shrink:0;">
        <p style="font-size:.72rem;letter-spacing:.08em;text-transform:uppercase;color:#8a867c;">You</p>
        <div style="display:flex;align-items:center;gap:.65rem;margin-top:.35rem;">
          <div>
            <p style="font-weight:600;"><%= profile?.user_name ?? 'Current user' %></p>
            <p style="font-size:.82rem;color:#666;"><%= profile?.bio || 'Ready to chat' %></p>
          </div>
          <% if (profile?.avatar_url) { %>
            <img
              src="<%= profile.avatar_url %>"
              alt="<%= profile.user_name %>"
              style="width:42px;height:42px;border-radius:50%;object-fit:cover;"
            />
          <% } else { %>
            <div
              style="width:42px;height:42px;border-radius:50%;display:grid;place-items:center;background:#534ab7;color:#fff;font-weight:700;font-size:1.1rem;"
            >
              <%= (profile?.user_name ?? 'U').charAt(0).toUpperCase() %>
            </div>
          <% } %>
        </div>
      </div>
    </div>

    <div
      class="chat-room-body"
      style="display:grid;grid-template-columns:220px minmax(0,1fr);min-height:560px;"
    >
      <aside
        class="chat-room-sidebar"
        style="border-right:1px solid #eceae3;padding:1.25rem;background:#faf9f5;"
      >
        <p style="font-size:.72rem;letter-spacing:.08em;text-transform:uppercase;color:#8a867c;">Participants</p>

        <div style="margin-top:1rem;display:grid;gap:.85rem;">
          <div style="display:flex;align-items:center;gap:.75rem;padding:.8rem;border-radius:14px;background:#fff;border:1px solid #eceae3;">
            <% if (profile?.avatar_url) { %>
              <img
                src="<%= profile.avatar_url %>"
                alt="<%= profile.user_name %>"
                style="width:40px;height:40px;border-radius:50%;object-fit:cover;"
              />
            <% } else { %>
              <div
                style="width:40px;height:40px;border-radius:50%;display:grid;place-items:center;background:#534ab7;color:#fff;font-weight:700;font-size:1.1rem;"
              >
                <%= (profile?.user_name ?? 'U').charAt(0).toUpperCase() %>
              </div>
            <% } %>
            <div style="min-width:0;">
              <p style="font-weight:600;"><%= profile?.user_name ?? 'You' %></p>
              <p style="font-size:.82rem;color:#666;">Current profile</p>
            </div>
          </div>

          <div style="display:flex;align-items:center;gap:.75rem;padding:.8rem;border-radius:14px;background:#fff;border:1px solid #eceae3;">
            <% if (chatprofile?.avatar_url) { %>
              <img
                src="<%= chatprofile.avatar_url %>"
                alt="<%= chatprofile.user_name %>"
                style="width:40px;height:40px;border-radius:50%;object-fit:cover;"
              />
            <% } else { %>
              <div
                style="width:40px;height:40px;border-radius:50%;display:grid;place-items:center;background:#534ab7;color:#fff;font-weight:700;"
              >
                <%= (chatprofile?.user_name ?? 'U').charAt(0).toUpperCase() %>
              </div>
            <% } %>
            <div style="min-width:0;">
              <p style="font-weight:600;"><%= chatprofile?.user_name ?? 'Chat user' %></p>
              <p style="font-size:.82rem;color:#666;">Conversation partner</p>
            </div>
          </div>
        </div>
      </aside>

      <section
        class="chat-room-main"
        style="display:flex;flex-direction:column;background:linear-gradient(180deg,#fcfbf8 0%,#f6f4ee 100%);"
      >
        <div style="padding:1.2rem 1.25rem;border-bottom:1px solid #eceae3;background:rgba(255,255,255,0.75);backdrop-filter:blur(6px);">
          <p style="font-size:.78rem;letter-spacing:.08em;text-transform:uppercase;color:#8a867c;">Direct chat</p>
          <h2 style="margin-top:.3rem;font-size:1rem;color:#201d18;">Message <%= chatprofile?.user_name ?? 'user' %></h2>
        </div>

        <div id="chat-thread" style="flex:1;padding:1.25rem;display:flex;flex-direction:column;gap:1rem;overflow:auto;">
          <% if (data && data.length > 0) { %>
            <% data.slice().reverse().forEach(function(message) { %>
              <% const mine = message.sender_id === profile.id; %>
              <div
                style="
                  align-self:<%= mine ? 'flex-end' : 'flex-start' %>;
                  max-width:72%;
                  padding:.9rem 1rem;
                  border-radius:<%= mine ? '18px 18px 6px 18px' : '18px 18px 18px 6px' %>;
                  background:<%= mine ? '#534ab7' : '#fff' %>;
                  color:<%= mine ? '#fff' : '#1a1a18' %>;
                  border:<%= mine ? 'none' : '1px solid #eceae3' %>;
                  box-shadow:<%= mine ? '0 10px 24px rgba(83,74,183,0.18)' : 'none' %>;
                "
              >
                <p style="font-weight:600;font-size:.88rem;margin-bottom:.2rem;">
                  <%= mine ? (profile?.user_name ?? 'You') : (chatprofile?.user_name ?? 'User') %>
                </p>
                <p style="white-space:pre-wrap;word-break:break-word;"><%= message.content %></p>
                <p
                  style="
                    margin-top:.45rem;
                    font-size:.74rem;
                    color:<%= mine ? 'rgba(255,255,255,0.78)' : '#7a766d' %>;
                    text-align:right;
                  "
                >
                  <%= new Date(message.created_at).toLocaleString() %>
                </p>
              </div>
            <% }) %>
          <% } else { %>
            <div
              style="margin:auto;max-width:420px;text-align:center;padding:1.5rem;border:1px dashed #d8d4cb;border-radius:18px;background:rgba(255,255,255,0.7);"
            >
              <p style="font-weight:600;font-size:1rem;color:#2a2722;">No messages yet</p>
              <p style="margin-top:.35rem;color:#6f6b63;">
                Start the conversation with <%= chatprofile?.user_name ?? 'this user' %>.
              </p>
            </div>
          <% } %>
        </div>

        <% if (meta && meta.totalPages > 1) { %>
          <div style="padding:0 1.25rem 1rem;display:flex;align-items:center;justify-content:space-between;gap:1rem;">
            <% if (meta.currentPage < meta.totalPages) { %>
              <a href="/chat/<%= chatprofile.id %>?page=<%= meta.currentPage + 1 %>" class="btn btn-sm btn-outline">Older</a>
            <% } else { %>
              <span></span>
            <% } %>

            <span style="font-size:.82rem;color:#666;">
              Page <%= meta.currentPage %> of <%= meta.totalPages %>
            </span>

            <% if (meta.currentPage > 1) { %>
              <a href="/chat/<%= chatprofile.id %>?page=<%= meta.currentPage - 1 %>" class="btn btn-sm btn-outline">Newer</a>
            <% } %>
          </div>
        <% } %>

        <form
          method="POST"
          action="/chat/<%= chatprofile.id %>"
          style="padding:1rem 1.25rem;border-top:1px solid #eceae3;background:#fff;display:flex;gap:.85rem;align-items:flex-end;"
        >
          <%- include('../partials/csrf-field') %>
          <div style="flex:1;">
            <label for="message" style="display:block;font-size:.8rem;font-weight:600;color:#666;margin-bottom:.45rem;">
              Message
            </label>
            <textarea
              id="message"
              name="message"
              rows="3"
              placeholder="Write a message to <%= chatprofile?.user_name ?? 'this user' %>..."
              style="width:100%;resize:none;padding:.85rem 1rem;border:1px solid #d9d6cf;border-radius:16px;background:#faf9f5;font:inherit;line-height:1.5;"
              required
            ></textarea>
          </div>
          <button type="submit" class="btn btn-primary" style="height:fit-content;padding:.8rem 1.25rem;">
            Send
          </button>
        </form>
      </section>
    </div>
  </div>
</div>

<script>
  (function () {
    const thread = document.getElementById('chat-thread');
    if (thread) {
      thread.scrollTop = thread.scrollHeight;
    }
  })();
</script>
