<div class="chat-room">
  <div class="chat-room-card">
    <div class="chat-room-header">
      <div class="chat-room-ident">
        <% if (chatprofile?.avatar_url) { %>
          <img
            src="<%= chatprofile.avatar_url %>"
            alt="<%= chatprofile.user_name %>"
            class="chat-avatar-lg"
          />
        <% } else { %>
          <div class="chat-avatar-fallback chat-avatar-fallback-lg">
            <%= (chatprofile?.user_name ?? 'U').charAt(0).toUpperCase() %>
          </div>
        <% } %>

        <div class="chat-room-ident-copy">
          <h1 class="chat-room-title"><%= chatprofile?.user_name ?? 'Chat user' %></h1>
          <p class="chat-room-subtitle">
            <%= chatprofile?.bio || 'Start the conversation.' %>
          </p>
        </div>
      </div>

      <div class="chat-room-self">
        <p class="chat-room-label">You</p>
        <div class="chat-room-self-row">
          <div>
            <p class="chat-room-self-name"><%= profile?.user_name ?? 'Current user' %></p>
            <p class="chat-room-self-bio"><%= profile?.bio || 'Ready to chat' %></p>
          </div>
          <% if (profile?.avatar_url) { %>
          <img
            src="<%= profile.avatar_url %>"
            alt="<%= profile.user_name %>"
              class="chat-avatar-md"
            />
          <% } else { %>
            <div class="chat-avatar-fallback chat-avatar-fallback-md chat-avatar-chat">
              <%= (profile?.user_name ?? 'U').charAt(0).toUpperCase() %>
            </div>
          <% } %>
        </div>
      </div>
    </div>

    <div class="chat-room-body">
      <aside class="chat-room-sidebar">
        <p class="chat-room-label">Participants</p>

        <div class="chat-room-participants">
          <div class="chat-room-user-card">
            <% if (profile?.avatar_url) { %>
              <img
                src="<%= profile.avatar_url %>"
                alt="<%= profile.user_name %>"
                class="chat-avatar-sm"
              />
            <% } else { %>
              <div class="chat-avatar-fallback chat-avatar-fallback-sm chat-avatar-chat">
                <%= (profile?.user_name ?? 'U').charAt(0).toUpperCase() %>
              </div>
            <% } %>
            <div class="chat-room-user-copy">
              <p class="chat-room-self-name"><%= profile?.user_name ?? 'You' %></p>
              <p class="chat-room-user-meta">Current profile</p>
            </div>
          </div>

          <div class="chat-room-user-card">
            <% if (chatprofile?.avatar_url) { %>
              <img
                src="<%= chatprofile.avatar_url %>"
                alt="<%= chatprofile.user_name %>"
                class="chat-avatar-sm"
              />
            <% } else { %>
              <div class="chat-avatar-fallback chat-avatar-fallback-sm chat-avatar-chat">
                <%= (chatprofile?.user_name ?? 'U').charAt(0).toUpperCase() %>
              </div>
            <% } %>
            <div class="chat-room-sidebar-copy">
              <p class="chat-room-self-name"><%= chatprofile?.user_name ?? 'Chat user' %></p>
              <p class="chat-room-user-meta">Conversation partner</p>
            </div>
          </div>
        </div>
      </aside>

      <section class="chat-room-main">
        <div class="chat-room-main-head">
          <p class="chat-room-label">Direct chat</p>
          <h2 class="chat-room-main-title">Message <%= chatprofile?.user_name ?? 'user' %></h2>
        </div>

        <div id="chat-thread" class="chat-thread">
          <% if (data && data.length > 0) { %>
            <% data.slice().reverse().forEach(function(message) { %>
              <% const mine = message.sender_id === profile.id; %>
              <div class="chat-bubble <%= mine ? 'chat-bubble-me' : 'chat-bubble-other' %>">
                <p class="chat-message-author">
                  <%= mine ? (profile?.user_name ?? 'You') : (chatprofile?.user_name ?? 'User') %>
                </p>
                <p class="chat-message-content"><%= message.content %></p>
                <p class="chat-message-time <%= mine ? 'chat-message-time-me' : 'chat-message-time-other' %>">
                  <%= new Date(message.created_at).toLocaleString() %>
                </p>
              </div>
            <% }) %>
          <% } else { %>
            <div class="chat-empty">
              <p class="chat-empty-title">No messages yet</p>
              <p class="chat-empty-copy">
                Start the conversation with <%= chatprofile?.user_name ?? 'this user' %>.
              </p>
            </div>
          <% } %>
        </div>

        <% if (meta && meta.totalPages > 1) { %>
          <div class="chat-pagination">
            <% if (meta.currentPage < meta.totalPages) { %>
              <a href="/chat/<%= chatprofile.id %>?page=<%= meta.currentPage + 1 %>" class="btn btn-sm btn-outline">Older</a>
            <% } else { %>
              <span></span>
            <% } %>

            <span class="chat-pagination-status">
              Page <%= meta.currentPage %> of <%= meta.totalPages %>
            </span>

            <% if (meta.currentPage > 1) { %>
              <a href="/chat/<%= chatprofile.id %>?page=<%= meta.currentPage - 1 %>" class="btn btn-sm btn-outline">Newer</a>
            <% } %>
          </div>
        <% } %>

        <form
          method="POST"
          action="/chat/<%= chatprofile.id %>"
          class="chat-compose"
        >
          <%- include('../partials/csrf-field') %>
          <div class="chat-compose-main">
            <label for="message" class="chat-compose-label">
              Message
            </label>
            <textarea
              id="message"
              name="message"
              rows="3"
              placeholder="Write a message to <%= chatprofile?.user_name ?? 'this user' %>..."
              class="chat-compose-input"
              required
            ></textarea>
          </div>
          <button type="submit" class="btn btn-primary chat-compose-submit">
            Send
          </button>
        </form>
      </section>
    </div>
  </div>
</div>

<script>
  (function () {
    const thread = document.getElementById('chat-thread');
    if (thread) {
      thread.scrollTop = thread.scrollHeight;
    }
  })();
</script>
