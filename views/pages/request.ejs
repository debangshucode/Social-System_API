<div class="notification-page">
    <h1>Follow Requests</h1>
    <h2 class="notification-pf-name">@<%= profile %></h2>

    <div class="notifications">
        <!-- follow requests  -->
        <ul class="user-list">
        <% fData.forEach(function(followReq) { %>
                <a href="/profile/<%= followReq.follower.id %>">
                    <li class="user-card">
                        <p style="width: 100%;">Follow request</p>
                        <div class="users-data">
                            <div class="user-card-avatar">
                                <% if (followReq.follower.avatar_url) { %>
                                    <img
                                        src="<%= followReq.follower.avatar_url %>"
                                        alt="<%= followReq.follower.user_name %>"
                                        class="avatar-sm"
                                    />
                                <% } else { %>
                                    <div class="avatar-sm avatar-placeholder">
                                    <%= followReq.follower.user_name.charAt(0).toUpperCase() %>
                                    </div>
                                <% } %>
                            </div>
                            <div class="user-card-info">
                                <span class="user-card-name"><%= followReq.follower.user_name %></span>
                                    <% if (followReq.follower.bio) { %>
                                        <span class="user-card-bio"><%= followReq.follower.bio %></span>
                                    <% } %>
                            </div>
                        </div>
                      

                        <div class="actions">
                            <!-- accept  -->
                            <form method="POST" action="/request/accept/<%= followReq.id %>">
                                <%- include('../partials/csrf-field') %>
                                <button type="submit" class="btn btn-green btn-sm">
                                  Accept
                                </button>
            
                            </form>

                            <!-- Reject -->
                            <form method="POST" action="/request/reject/<%= followReq.id %>">
                               <%- include('../partials/csrf-field') %>
                               <button type="submit" class="btn btn-danger btn-sm">
                                 Reject
                               </button>
                            </form>
                        </div>

                    </li>
                </a>
        <% }) %>
      </ul>
      <% if (fMeta && fMeta.totalPages > 1) { %>
        <div class="pagination">
            <% if (fMeta.currentPage > 1) { %>
            <a href="/requests?page=<%= fMeta.currentPage - 1 %>" class="btn btn-sm btn-outline">&larr; Prev</a>
            <% } %>

            <span class="page-info">
            Page <%= fMeta.currentPage %> of <%= fMeta.totalPages %>
            </span>

            <% if (fMeta.currentPage < fMeta.totalPages) { %>
            <a href="/requests?page=<%= fMeta.currentPage + 1 %>" class="btn btn-sm btn-outline">Next &rarr;</a>
            <% } %>
        </div>
    <% } %>

    </div>
</div>
